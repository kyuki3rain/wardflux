{
  "name": "wardflux",
  "private": true,
  "version": "0.0.0",
  "description": "都市人流カードゲーム MVP — balance & fun verification harness",
  "type": "module",
  "scripts": {
    "test": "pnpm --filter @wardflux/core test",
    "typecheck": "pnpm -r typecheck",
    "build:web": "pnpm --filter @wardflux/web build",
    "dev:web": "pnpm --filter @wardflux/web dev",
    "dev:server": "pnpm --filter @wardflux/server dev",
    "deploy:server": "pnpm --filter @wardflux/server deploy",
    "sim": "pnpm --filter @wardflux/sim start"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "packageManager": "pnpm@11.6.0"
}
